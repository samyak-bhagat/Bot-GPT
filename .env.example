APP_NAME=bot-gpt-backend
APP_ENV=dev
API_PORT=8000
UI_PORT=8501
API_BASE_URL=http://api:8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=botgpt
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_URI=postgresql+psycopg://postgres:postgres@db:5432/botgpt

REDIS_URL=redis://cache:6379/0

# -----------------------------------------------------------------------------
# LLM configuration (choose OpenAI vs Fully Local)
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Option A (OpenAI / cloud):
  DEFAULT_PROVIDER=openai
  DEFAULT_MODEL=gpt-4o-mini
  OPENAI_API_KEY=
#
# Option B (Fully Local):
#   DEFAULT_PROVIDER=ollama
#   DEFAULT_MODEL=qwen3:1.7b
#   (Ollama runs as a Docker service named `ollama` in docker-compose.yml)
# -----------------------------------------------------------------------------




# ---- Embeddings (local by default) ----
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- OpenAI (only used if you switch to openai) ----
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Groq (optional; unused in local mode) ----
GROQ_API_KEY=
